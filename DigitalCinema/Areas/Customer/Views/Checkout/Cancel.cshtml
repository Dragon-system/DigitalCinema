@{
    ViewData["Title"] = "Payment Cancelled";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh; padding-top: 100px;">
    <div class="row justify-content-center w-100">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-center">
                <!-- الجزء العلوي (أيقونة الإلغاء) -->
                <div class="card-header bg-light py-5 border-0">
                    <div class="display-1 text-warning mb-3">
                        <i class="bi bi-x-circle-fill"></i>
                    </div>
                    <h2 class="fw-bold text-dark">تم إلغاء الدفع</h2>
                    <p class="text-muted px-4">
                        لقد قمت بإلغاء عملية الدفع. لا تقلق، لم يتم خصم أي مبالغ من حسابك، وتم تنظيف حجوزاتك المعلقة لتتمكن من البدء من جديد.
                    </p>
                </div>

                <div class="card-body p-4">
                    <!-- تفاصيل إضافية للمستخدم -->
                    <div class="alert alert-secondary border-0 rounded-3 mb-4 small text-start">
                        <ul class="mb-0">
                            <li>لم يتم إصدار أي تذاكر لهذه العملية.</li>
                            <li>المقاعد التي اخترتها أصبحت متاحة الآن للآخرين.</li>
                            <li>يمكنك إعادة محاولة الحجز في أي وقت.</li>
                        </ul>
                    </div>

                    <!-- الأزرار -->
                    <div class="d-grid gap-2">
                        <a asp-area="Customer" asp-controller="Home" asp-action="Index"
                           class="btn btn-dark btn-lg rounded-3 shadow-sm">
                            <i class="bi bi-house-door me-2"></i> العودة للرئيسية
                        </a>

                        <p class="mt-3 mb-0">
                            <span class="text-muted">هل تريد تغيير رأيك؟</span>
                            <a href="javascript:history.back()" class="text-primary fw-bold text-decoration-none">
                                العودة لاختيار المقاعد
                            </a>
                        </p>
                    </div>
                </div>

                <div class="card-footer bg-white py-3 border-0">
                    <small class="text-muted">نحن دائماً في انتظارك للاستمتاع بأحدث الأفلام!</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- إذا كنت تريد إضافة أنيميشن بسيط عند ظهور الصفحة -->
    <script src="https://jsdelivr.net"></script>
    <script>
        // لا نحتاج كونفيتي هنا لأنها حالة إلغاء، لكن يمكن إضافة تأثير اهتزاز بسيط (Shake)
    </script>
}
