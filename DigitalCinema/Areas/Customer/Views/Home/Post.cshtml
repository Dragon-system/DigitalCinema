@model List<PostVM>
@{
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
    ViewData["Title"] = "إعلانات DE Cinema";
}

<style>
    .posts-page {
        min-height: 100vh;
        padding: 100px 20px 50px; /* فوق - يمين/شمال - تحت */
        font-family: 'Cairo', sans-serif;
    }

    .posts-wrapper {
        max-width: 680px;
        margin: 0 auto;
    }

    .page-hero {
        text-align: center;
        margin-bottom: 40px;
    }

        .page-hero h1 {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #f0d080, #c9a84c);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 6px;
        }

        .page-hero p {
            color: #7a7a9a;
            font-size: .85rem;
        }

    /* ── البوست ── */
    .post-card {
        background: rgba(13, 13, 26, 0.8);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(201,168,76,.2);
        border-radius: 20px;
        margin-bottom: 24px;
        overflow: hidden;
        animation: cardIn .4s cubic-bezier(.22,1,.36,1) both;
        transition: border-color .3s, box-shadow .3s;
    }

        .post-card:hover {
            border-color: rgba(201,168,76,.4);
            box-shadow: 0 0 30px rgba(201,168,76,.08);
        }

    @@keyframes cardIn {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .post-body {
        padding: 20px 24px;
    }

    .post-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 18px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(201,168,76,.08);
    }

    .post-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        object-fit: cover;
        border: 1.5px solid rgba(201,168,76,.3);
    }

    .post-author {
        font-size: .88rem;
        font-weight: 700;
        color: #e8e8f4;
    }

    .post-date {
        font-size: .72rem;
        color: #5a5a7a;
    }

    .post-content {
        padding: 10px 18px;
        color: #c8c8e0;
        font-size: .9rem;
        line-height: 1.7;
    }

    .post-media img, .post-media video {
        width: 100%;
        max-height: 380px;
        object-fit: cover;
        display: block;
    }

    /* ── التفاعلات ── */
    .post-actions {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 12px 24px;
        border-top: 1px solid rgba(201,168,76,.08);
    }

    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: none;
        border: none;
        color: #7a7a9a;
        font-size: .82rem;
        font-family: 'Cairo', sans-serif;
        cursor: pointer;
        padding: 6px 12px;
        border-radius: 8px;
        transition: .2s;
        text-decoration: none;
    }

        .action-btn:hover {
            background: rgba(201,168,76,.08);
            color: #c9a84c;
        }

        .action-btn.liked {
            color: #c9a84c;
        }

        .action-btn i {
            font-size: 1rem;
        }

    /* ── التعليقات ── */
    .comments-section {
        padding: 0 24px 16px;
        display: none;
    }

        .comments-section.open {
            display: block;
        }

    .comment-item {
        display: flex;
        gap: 10px;
        margin-bottom: 12px;
        animation: fadeIn .3s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .comment-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid rgba(201,168,76,.2);
        flex-shrink: 0;
    }

    .comment-bubble {
        background: rgba(201,168,76,.06);
        border: 1px solid rgba(201,168,76,.1);
        border-radius: 12px;
        padding: 8px 14px;
        flex: 1;
    }

    .comment-author {
        font-size: .75rem;
        font-weight: 700;
        color: #c9a84c;
        margin-bottom: 2px;
    }

    .comment-text {
        font-size: .82rem;
        color: #c8c8e0;
    }

    .comment-form {
        display: flex;
        gap: 10px;
        margin-top: 12px;
        border-top: 1px solid rgba(201,168,76,.08);
        padding-top: 12px;
    }

    .comment-input {
        flex: 1;
        background: rgba(18, 18, 32, 0.8);
        border: 1.5px solid rgba(201,168,76,.15);
        border-radius: 10px;
        color: #e2e2f0;
        font-size: .82rem;
        padding: 8px 14px;
        outline: none;
        font-family: 'Cairo', sans-serif;
        transition: .3s;
    }

        .comment-input:focus {
            border-color: #c9a84c;
            box-shadow: 0 0 0 3px rgba(201,168,76,.1);
        }

        .comment-input::placeholder {
            color: #3a3a5a;
        }

    .btn-comment-send {
        background: linear-gradient(135deg, #c9a84c, #8b5e1a);
        border: none;
        border-radius: 10px;
        color: #fff;
        padding: 8px 16px;
        font-size: .82rem;
        cursor: pointer;
        font-family: 'Cairo', sans-serif;
        transition: .2s;
    }

        .btn-comment-send:hover {
            transform: translateY(-1px);
        }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: #5a5a7a;
    }

        .empty-state i {
            font-size: 3rem;
            color: rgba(201,168,76,.3);
            margin-bottom: 16px;
            display: block;
        }
</style>

<div class="posts-page">
    <div class="posts-wrapper">

        <div class="page-hero">
            <h1><i class="bi bi-megaphone"></i> إعلانات DE Cinema</h1>
            <p>آخر الأفلام والعروض الحصرية</p>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-camera-reels"></i>
                <p>لا توجد إعلانات حتى الآن</p>
            </div>
        }

        @foreach (var post in Model)
        {
            <div class="post-card">
                <div class="post-body">
                    <div class="post-header">
                        <div class="post-author-wrap">
                                <img class="post-avatar"
                                     src="@(string.IsNullOrEmpty(post.AuthorImage) ? "https://bootdey.com/img/Content/avatar/avatar7.png" : $"/images/Profile/{post.AuthorImage}")"
                                     alt="avatar" />
                                <div>
                                    <div class="post-author">@post.AuthorName</div>
                                    <div class="post-date">@post.CreatedAt.ToString("dd/MM/yyyy - hh:mm tt")</div>
                                </div>
                         </div>
                    </div>
                </div>
                <div class="post-content">
                    @post.Content
                </div>
               

                @if (!string.IsNullOrEmpty(post.ImagePath))
                {
                    <div class="post-media">
                        <img src="/images/PostImages/@post.ImagePath" alt="post image" style="width:70%; max-height:280px; object-fit:cover; border-radius:12px; display:block; margin:0 auto;" />
                    </div>
                }

                @if (!string.IsNullOrEmpty(post.VideoPath))
                {
                    <div class="post-media">
                        <video controls src="/images/PostVideos/@post.VideoPath" style="width:70%; max-height:280px; object-fit:cover; border-radius:12px; display:block; margin:0 auto;"></video>
                    </div>
                }

                @* ── التفاعلات ── *@
                <div class="post-actions">

                    @* لايك *@
                    <form asp-area="Customer" asp-controller="Home" asp-action="Like" asp-route-postId="@post.Id" method="post">
                        <button type="button"
                                class="action-btn @(post.IsLikedByCurrentUser ? "liked" : "")"
                                onclick="toggleLike(@post.Id, this)">
                            <i class="bi @(post.IsLikedByCurrentUser ? "bi-heart-fill" : "bi-heart")"></i>
                            <span class="like-count">@post.LikesCount</span>
                        </button>
                    </form>

                    @* كومنت *@
                    <button class="action-btn" onclick="toggleComments(@post.Id)">
                        <i class="bi bi-chat"></i>
                        @post.Comments.Count تعليق
                    </button>

                </div>

                @* ── التعليقات ── *@
                <div class="comments-section" id="comments-@post.Id">

                    @foreach (var comment in post.Comments)
                    {
                        <div class="comment-item">
                            <img class="comment-avatar"
                                 src="@(string.IsNullOrEmpty(comment.AuthorImage) ? "https://bootdey.com/img/Content/avatar/avatar7.png" : $"/images/Profile/{comment.AuthorImage}")"
                                 alt="avatar" />
                            <div class="comment-bubble">
                                <div class="comment-author">@comment.AuthorName</div>
                                <div class="comment-text">@comment.Content</div>
                            </div>
                        </div>
                    }

                    @* فورم التعليق *@
                    @* <form asp-area="Customer" asp-controller="Home" asp-action="Comment" method="post"> *@
                        <div class="comment-form">
                            <input type="text" id="comment-input-@post.Id" class="comment-input" placeholder="اكتب تعليقاً..." />
                            <button type="button" class="btn-comment-send" onclick="addComment(@post.Id)">
                                <i class="bi bi-send"></i>
                            </button>
                        </div>
                    @* </form> *@

                </div>

            </div>
           
        }

    </div>
</div>

@section Scripts {
    <partial name="_NotifictionPartial">
        <script>
            function toggleComments(postId) {
                const section = document.getElementById('comments-' + postId);
                section.classList.toggle('open');
            }
        </script>
        
}
    <script>
        async function toggleLike(postId, btn) {
            const response = await fetch(`/Customer/Home/Like?postId=${postId}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value }
            });

            if (response.ok) {
                const icon = btn.querySelector('i');
                const count = btn.querySelector('.like-count');
                const isLiked = btn.classList.toggle('liked');
                icon.className = isLiked ? 'bi bi-heart-fill' : 'bi bi-heart';
                count.textContent = parseInt(count.textContent) + (isLiked ? 1 : -1);
            }
        }

        async function addComment(postId) {
            const input = document.getElementById('comment-input-' + postId);
            const content = input.value.trim();
            if (!content) return;

            const formData = new FormData();
            formData.append('postId', postId);
            formData.append('content', content);

            const response = await fetch('/Customer/Home/Comment', {
                method: 'POST',
                body: formData
            });

            if (response.ok) {
                // امسح الـ input
                input.value = '';

                // ضيف الكومنت في الصفحة من غير refresh
                const section = document.getElementById('comments-' + postId);
                const div = document.createElement('div');
                div.className = 'comment-item';
                div.innerHTML = `
                    <img class="comment-avatar" src="https://bootdey.com/img/Content/avatar/avatar7.png" alt="avatar" />
                    <div class="comment-bubble">
                        <div class="comment-author">أنت</div>
                        <div class="comment-text">${content}</div>
                    </div>`;
                section.insertBefore(div, section.querySelector('.comment-form'));
            }
        }</script>
