@model NewPasswordVM
@{
    ViewData["Title"] = "NewPassword";
}

<div class="logo-area">
    <div class="logo-icon">
        <i class="bi bi-person-plus-fill"></i>
    </div>
    <div class="logo-name">DE Cinema</div>
    <div class="logo-tag">انضم لعالم الرفاهية</div>
</div>

<div class="gold-line"></div>


<p class="form-sub">استمتع بمزايا الحجز الحصري وأحدث العروض السينمائية</p>


<div class="container my-3">

    @* ── Background effects ── *@
    <div class="bg-blobs"></div>
    <div class="stars-layer" id="stars"></div>

    @* ── Logo ── *@
    <div class="logo-area">
        <div class="logo-icon">
            <i class="bi bi-film"></i>
        </div>
        <div class="logo-name">DE Cinema</div>
        <div class="logo-tag">تجربة السينما الفاخرة</div>
    </div>

    <div class="gold-line"></div>

    <div class="row">
        <div class="col-md-12">
            <form asp-action="NewPassword">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="input-wrap">
                    <label asp-for="CurrentPassword" class="field-label"></label>
                    <input asp-for="CurrentPassword"
                           class="cin-input"
                           id="CurrentPassword"
                           autocomplete="current-password" />
                    <i class="bi bi-lock input-icon-r"></i>
                    <button type="button" class="eye-btn" onclick="togglePass()" title="إظهار / إخفاء">
                        <i class="bi bi-eye" id="eyeIco"></i>
                    </button>
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>

                <div class="input-wrap">
                    <label asp-for="NewPassword" class="field-label"></label>
                    <input asp-for="NewPassword"
                           class="cin-input"
                           id="NewPassword"
                           autocomplete="new-password" />
                    <i class="bi bi-lock input-icon-r"></i>
                    <button type="button" class="eye-btn" onclick="togglePass()" title="إظهار / إخفاء">
                        <i class="bi bi-eye" id="eyeIco"></i>
                    </button>
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="input-wrap">
                    <label asp-for="ConfirmPassword" class="field-label"></label>
                    <input asp-for="ConfirmPassword"
                           class="cin-input"
                           id="ConfirmPassword"
                           autocomplete="new-password" />
                    <i class="bi bi-lock input-icon-r"></i>
                    <button type="button" class="eye-btn" onclick="togglePass()" title="إظهار / إخفاء">
                        <i class="bi bi-eye" id="eyeIco"></i>
                    </button>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                @* <div class="form-group">
                    <label asp-for="ConfirmPassword" class="control-label"></label>
                    <input asp-for="ConfirmPassword" class="cin-input" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div> *@
                <div class="form-group mt-3">
                    <input type="submit" value="Change Password" class="btn btn-primary" />
                </div>
                
                <p class="form-sub">The password must contain the symbols (A...a.!.#.$.123)</p>
             
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotifictionPartial" />
}