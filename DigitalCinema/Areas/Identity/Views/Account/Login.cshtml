@model LoginVM
@{
    ViewData["Title"] = "تسجيل الدخول";
}

@* ── Background effects ── *@
<div class="bg-blobs"></div>

@* ══════════════════════ LOGIN CARD ══════════════════════ *@
<div class="page-center">
    <div class="login-wrapper">
        <div class="cinema-card">

            @* ── Logo ── *@
            <div class="logo-area">
                <div class="logo-icon">
                    <i class="bi bi-film"></i>
                </div>
                <div class="logo-name">DE Cinema</div>
                <div class="logo-tag">تجربة السينما الفاخرة</div>
            </div>

            <div class="gold-line"></div>

            <p class="form-heading">مرحباً بعودتك 👋</p>
            <p class="form-sub">سجّل دخولك لمتابعة حجوزاتك وأفلامك المفضّلة</p>

            @* ── Validation Summary ── *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-cinema" role="alert">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    <div asp-validation-summary="All" class="d-inline"></div>
                </div>
            }

            @* ══ FORM ══ *@
            <form asp-action="Login" method="post">

                @* ── Email / Username ── *@
                <div class="input-wrap">
                    <label asp-for="UserNameOrEmail" class="field-label"></label>
                    <input asp-for="UserNameOrEmail" class="cin-input" />
                    <i class="bi bi-envelope input-icon-r"></i>
                    <span asp-validation-for="UserNameOrEmail" class="text-danger"></span>
                </div>

                @* ── Password ── *@
                <div class="input-wrap">
                    <label asp-for="Password" class="field-label"></label>
                    <input asp-for="Password"
                           class="cin-input"
                           id="Password"
                           autocomplete="current-password" />
                    <i class="bi bi-lock input-icon-r"></i>
                    <button type="button" class="eye-btn" onclick="togglePass()" title="إظهار / إخفاء">
                        <i class="bi bi-eye" id="eyeIco"></i>
                    </button>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                @* ── Remember Me / Forgot ── *@
                <div class="meta-row">
                    <div class="form-group form-check mb-0">
                        <label class="form-check-label" style="color:#7a7a9a;">
                            <input class="form-check-input" asp-for="RememberMe" />
                            @Html.DisplayNameFor(model => model.RememberMe)
                        </label>

                @* ── Submit ── *@
                <button type="submit" class="btn-cinema">
                    <i class="bi bi-box-arrow-in-right me-2"></i> تسجيل الدخول
                </button>

            </form>

            @* ── Links ── *@
            <div class="or-div"><span>روابط سريعة</span></div>
            <div style="display:flex; flex-direction:column; gap:8px; text-align:center; margin-top:10px;">
                <a asp-action="Register" style="color:#c9a84c; font-size:.85rem; text-decoration:none;">
                    <i class="bi bi-person-plus me-1"></i> إنشاء حساب جديد
                </a>
                <a asp-action="ResendEmailConfirmation" style="color:#7a7a9a; font-size:.8rem; text-decoration:none;">
                    <i class="bi bi-envelope-arrow-up me-1"></i> إعادة إرسال بريد التأكيد
                </a>
                <a asp-action="ForgetPassword" style="color:#7a7a9a; font-size:.8rem; text-decoration:none;">
                    <i class="bi bi-key me-1"></i> نسيت كلمة المرور؟
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotifictionPartial">

}
