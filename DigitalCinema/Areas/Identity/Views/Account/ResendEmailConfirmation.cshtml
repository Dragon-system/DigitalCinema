@model DigitalCinema.ViewModel.ResendEmailConfirmationVM

@{
    ViewData["Title"] = "ResendEmailConfirmation";
}
<div class="bg-blobs"></div>
<div class="stars-layer" id="stars"></div>

<div class="page-center">
    <div class="login-wrapper">
        <div class="cinema-card">
            <div class="logo-area">
                <div class="logo-icon">
                    <i class="bi bi-film"></i>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <form asp-action="ResendEmailConfirmation">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-group">
                        <label asp-for="EmailOrUsername" class="control-label"></label>
                        <input asp-for="EmailOrUsername" class="form-control" />
                        <span asp-validation-for="EmailOrUsername" class="text-danger"></span>
                    </div>
                    <div class="form-group mt-3">
                        <input type="submit" value="Create" class="btn btn-primary" />
                    </div>
                </form>
            </div>
        </div>
            <div>
        <a asp-action="Login">Back to Login</a>
    </div>
    
</div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotifictionPartial">
}
