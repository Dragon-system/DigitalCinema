@model ChangePasswordVM
@{
    ViewData["Title"] = "ChangePassword";
}


<div class="container my-3">

    @* ── Background effects ── *@
    <div class="bg-blobs"></div>
    <div class="stars-layer" id="stars"></div>

    @* ── Logo ── *@
    <div class="logo-area">
        <div class="logo-icon">
            <i class="bi bi-film"></i>
        </div>
        <div class="logo-name">DE Cinema</div>
        <div class="logo-tag">تجربة السينما الفاخرة</div>
    </div>

    <div class="gold-line"></div>

    <div class="row">
        <div class="col-md-12">
            <form asp-action="ChangePassword">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="input-wrap">
                    <label asp-for="Password" class="field-label"></label>
                    <input asp-for="Password"
                           class="cin-input"
                           id="Password"
                           autocomplete="current-password" />
                    <i class="bi bi-lock input-icon-r"></i>
                    <button type="button" class="eye-btn" onclick="togglePass()" title="إظهار / إخفاء">
                        <i class="bi bi-eye" id="eyeIco"></i>
                    </button>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="input-wrap">
                    <label asp-for="ConfirmPassword" class="field-label"></label>
                    <input asp-for="ConfirmPassword"
                           class="cin-input"
                           id="Password"
                        
                           autocomplete="current-password" />
                    <i class="bi bi-lock input-icon-r"></i>
                    <button type="button" class="eye-btn" onclick="togglePass()" title="إظهار / إخفاء">
                        <i class="bi bi-eye" id="eyeIco"></i>
                    </button>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                @* <div class="form-group">
                    <label asp-for="ConfirmPassword" class="control-label"></label>
                    <input asp-for="ConfirmPassword" class="cin-input" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div> *@
                <div class="form-group mt-3">
                    <input type="submit" value="Create" class="btn btn-primary" />
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotifictionPartial" />
}