@model MACSHomeVM
<div class="container-fluid py-4">
    <div class="row g-3 mb-3">

        <!-- إحصائيات الأفلام -->
        <div class="col-md-6 col-xxl-3">
            <div class="card h-100 shadow-sm border-0 border-top border-primary border-3">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col">
                            <h6 class="text-700 mb-1 fw-bold">Movis</h6>
                            <div class="display-6 fw-bold text-primary">@Model.MoviesCount</div>
                        </div>
                        <div class="col-auto">
                            <div class="bg-soft-primary p-3 rounded-circle">
                                <span class="fas fa-film text-primary fs-2"></span>
                            </div>
                        </div>
                    </div>
                    <hr class="my-3 border-200">
                    <a asp-controller="Movie" asp-action="Index" class="btn btn-link p-0 text-primary fw-semi-bold fs--1 decoration-none">
                        Mineu Movies<span class="fas fa-chevron-right ms-1 fs--2"></span>
                    </a>
                </div>
            </div>
        </div>

        <!-- إحصائيات السينمات -->
        <div class="col-md-6 col-xxl-3">
            <div class="card h-100 shadow-sm border-0 border-top border-success border-3">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col">
                            <h6 class="text-700 mb-1 fw-bold">Cuont Cinemas</h6>
                            <div class="display-6 fw-bold text-success">@Model.CinemasCount</div>
                        </div>
                        <div class="col-auto">
                            <div class="bg-soft-success p-3 rounded-circle">
                                <span class="fas fa-video text-success fs-2"></span>
                            </div>
                        </div>
                    </div>
                    <hr class="my-3 border-200">
                    <a asp-controller="Cinema" asp-action="Index" class="btn btn-link p-0 text-success fw-semi-bold fs--1 decoration-none">
                        Mineu Cinemas <span class="fas fa-chevron-right ms-1 fs--2"></span>
                    </a>
                </div>
            </div>
        </div>

        <!-- إحصائيات الممثلين -->
        <div class="col-md-6 col-xxl-3">
            <div class="card h-100 shadow-sm border-0 border-top border-info border-3">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col">
                            <h6 class="text-700 mb-1 fw-bold">Mineu Actors</h6>
                            <div class="display-6 fw-bold text-info">@Model.ActorsCount</div>
                        </div>
                        <div class="col-auto">
                            <div class="bg-soft-info p-3 rounded-circle">
                                <span class="fas fa-users text-info fs-2"></span>
                            </div>
                        </div>
                    </div>
                    <hr class="my-3 border-200">
                    <a asp-controller="Actor" asp-action="Index" class="btn btn-link p-0 text-info fw-semi-bold fs--1 decoration-none">
                        Mineu Actors <span class="fas fa-chevron-right ms-1 fs--2"></span>
                    </a>
                </div>
            </div>
        </div>

        @* <!-- إحصائيات معرض الصور -->
        <div class="col-md-6 col-xxl-3">
            <div class="card h-100 shadow-sm border-0 border-top border-warning border-3">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col">
                            <h6 class="text-700 mb-1 fw-bold">صور المعرض</h6>
                            <div class="display-6 fw-bold text-warning">@ViewBag.SubImgsCount</div>
                        </div>
                        <div class="col-auto">
                            <div class="bg-soft-warning p-3 rounded-circle">
                                <span class="fas fa-images text-warning fs-2"></span>
                            </div>
                        </div>
                    </div>
                    <hr class="my-3 border-200">
                    <button class="btn btn-link p-0 text-warning fw-semi-bold fs--1 decoration-none">
                        عرض الألبوم <span class="fas fa-chevron-right ms-1 fs--2"></span>
                    </button>
                </div>
            </div>
        </div> *@

    </div>
</div>

<style>
    /* لمسة جمالية: جعل الكارت يرتفع عند مرور الماوس */
    .card {
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .decoration-none {
        text-decoration: none !important;
    }

    .bg-soft-primary {
        background-color: rgba(44, 123, 229, 0.1);
    }

    .bg-soft-success {
        background-color: rgba(0, 210, 149, 0.1);
    }

    .bg-soft-info {
        background-color: rgba(39, 188, 253, 0.1);
    }

    .bg-soft-warning {
        background-color: rgba(245, 128, 54, 0.1);
    }
</style>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotifictionPartial">
}
