@model CreaetPostVM
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "إضافة منشور جديد";
}

<style>
    .create-post-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
        font-family: 'Cairo', sans-serif;
    }

    .create-wrapper {
        width: 100%;
        max-width: 700px;
    }

    .gold-card {
        background: rgba(13, 13, 26, 0.85);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(201,168,76,.35);
        border-radius: 24px;
        padding: 40px 50px;
        box-shadow: 0 0 0 1px rgba(201,168,76,.08), 0 0 40px rgba(201,168,76,.12), 0 0 80px rgba(201,168,76,.06), 0 40px 80px rgba(0,0,0,.5);
        animation: cardIn .5s cubic-bezier(.22,1,.36,1) both;
    }

    @@keyframes cardIn {
        from {
            opacity: 0;
            transform: translateY(20px) scale(.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .page-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #e8e8f4;
        margin-bottom: 6px;
    }

    .page-sub {
        color: #7a7a9a;
        font-size: .82rem;
        margin-bottom: 28px;
    }

    .gold-line {
        height: 1px;
        background: linear-gradient(90deg, transparent, #c9a84c, transparent);
        opacity: .2;
        margin: 20px 0 28px;
    }

    .field-label {
        font-size: .75rem;
        color: #c9a84c;
        font-weight: 700;
        margin-bottom: 6px;
        display: block;
    }

    .cin-textarea {
        width: 100%;
        background: rgba(18, 18, 32, 0.8);
        border: 1.5px solid rgba(201,168,76,.15);
        border-radius: 12px;
        color: #e2e2f0;
        font-size: .88rem;
        padding: 12px 16px;
        outline: none;
        transition: all .3s ease;
        box-sizing: border-box;
        font-family: 'Cairo', sans-serif;
        resize: vertical;
        min-height: 130px;
    }

        .cin-textarea:focus {
            border-color: #c9a84c;
            box-shadow: 0 0 0 4px rgba(201,168,76,.1);
        }

        .cin-textarea::placeholder {
            color: #3a3a5a;
        }

    /* ── Upload Area ── */
    .upload-area {
        border: 1.5px dashed rgba(201,168,76,.25);
        border-radius: 12px;
        padding: 24px;
        text-align: center;
        cursor: pointer;
        transition: .3s;
        position: relative;
    }

        .upload-area:hover {
            border-color: rgba(201,168,76,.5);
            background: rgba(201,168,76,.04);
        }

    .upload-icon {
        font-size: 1.8rem;
        color: #c9a84c;
        margin-bottom: 8px;
    }

    .upload-text {
        color: #7a7a9a;
        font-size: .8rem;
    }

        .upload-text span {
            color: #c9a84c;
        }

    .preview-wrap {
        margin-top: 12px;
        display: none;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(201,168,76,.2);
    }

        .preview-wrap img, .preview-wrap video {
            width: 100%;
            max-height: 250px;
            object-fit: cover;
            display: block;
        }

    .input-wrap {
        margin-bottom: 20px;
    }

    /* ── الأزرار ── */
    .actions-row {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 28px;
    }

    .btn-gold {
        background: linear-gradient(135deg, #c9a84c, #8b5e1a);
        border: none;
        border-radius: 12px;
        color: #fff;
        padding: 11px 30px;
        font-size: .88rem;
        font-weight: 700;
        cursor: pointer;
        font-family: 'Cairo', sans-serif;
        transition: transform .2s, box-shadow .2s;
        box-shadow: 0 6px 20px rgba(201,168,76,.25);
    }

        .btn-gold:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(201,168,76,.35);
        }

    .btn-ghost {
        background: transparent;
        border: 1px solid rgba(201,168,76,.2);
        border-radius: 12px;
        color: #7a7a9a;
        padding: 11px 24px;
        font-size: .88rem;
        font-family: 'Cairo', sans-serif;
        cursor: pointer;
        transition: .2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn-ghost:hover {
            border-color: rgba(201,168,76,.4);
            color: #c9a84c;
        }

    .validation-error {
        color: #ff6b6b;
        font-size: .75rem;
        margin-top: 4px;
        display: block;
    }
</style>

<div class="create-post-page">
    <div class="create-wrapper">
        <div class="gold-card">

            <p class="page-title"><i class="bi bi-megaphone me-2" style="color:#c9a84c"></i>إضافة منشور جديد</p>
            <p class="page-sub">أضف إعلان فيلم أو عرض سينما للمتابعين</p>

            <div class="gold-line"></div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div style="background:rgba(255,107,107,.1); border:1px solid rgba(255,107,107,.3); border-radius:12px; padding:12px 16px; margin-bottom:20px; color:#ff6b6b; font-size:.82rem;">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    <div asp-validation-summary="All" class="d-inline"></div>
                </div>
            }

            <form asp-action="Create" method="post" enctype="multipart/form-data">

                @* ── المحتوى ── *@
                <div class="input-wrap">
                    <label class="field-label">محتوى المنشور</label>
                    <textarea name="Content" class="cin-textarea" placeholder="اكتب تفاصيل الفيلم أو العرض...">@Model?.Content</textarea>
                    <span asp-validation-for="Content" class="validation-error"></span>
                </div>

                @* ── الصورة ── *@
                <div class="input-wrap">
                    <label class="field-label">صورة المنشور (اختياري)</label>
                    <div class="upload-area" onclick="document.getElementById('imageInput').click()">
                        <div class="upload-icon"><i class="bi bi-image"></i></div>
                        <div class="upload-text">اضغط لرفع صورة — <span>JPG, PNG, WEBP</span></div>
                    </div>
                    <input type="file" id="imageInput" name="Image" accept="image/*"
                           onchange="previewFile(event, 'imagePreview', 'img')" style="display:none" />
                    <div class="preview-wrap" id="imagePreview">
                        <img src="" alt="preview" />
                    </div>
                </div>

                @* ── الفيديو ── *@
                <div class="input-wrap">
                    <label class="field-label">فيديو المنشور (اختياري)</label>
                    <div class="upload-area" onclick="document.getElementById('videoInput').click()">
                        <div class="upload-icon"><i class="bi bi-camera-video"></i></div>
                        <div class="upload-text">اضغط لرفع فيديو — <span>MP4, MOV</span></div>
                    </div>
                    <input type="file" id="videoInput" name="Video" accept="video/*"
                           onchange="previewFile(event, 'videoPreview', 'video')" style="display:none" />
                    <div class="preview-wrap" id="videoPreview">
                        <video controls src=""></video>
                    </div>
                </div>

                <div class="actions-row">
                    <a asp-action="Index" class="btn-ghost">
                        <i class="bi bi-arrow-right"></i> إلغاء
                    </a>
                    <button type="submit" class="btn-gold">
                        <i class="bi bi-send me-1"></i> نشر الإعلان
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotifictionPartial">

        <script>
            function previewFile(event, previewId, type) {
                const file = event.target.files[0];
                if (!file) return;
                const wrap = document.getElementById(previewId);
                const el = wrap.querySelector(type);
                el.src = URL.createObjectURL(file);
                wrap.style.display = 'block';
            }
        </script>
}
