@model MovieCreateModelVM

<div class="container">
    <div class="row mb-3 my-3">
        <div class="col-md-6">
            <h2 class="display-6">Create Movie</h2>
        </div>
    </div>

    <div class="custom-form">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="row">
                <!-- اسم الفيلم -->
                <div class="col-md-12 mb-3">
                    <label class="form-label">Name</label>
                    <input class="form-control" placeholder="Movie Name" name="Name">
                    <span asp-validation-for="Movies.Name"></span>
                </div>

                <!-- اختيار الممثلين (يجب استخدام قائمة الممثلين المتاحة بالكامل) -->
                <div class="col-md-12 mb-3">
                    <label class="form-label">Select Actors</label>
                    <select name="selectedActorIds" class="form-select" multiple style="height: 150px;">
                        @foreach (var actor in Model.Actors) @* تأكد من وجود قائمة Actors في الـ ViewModel *@
                        {
                            <option value="@actor.Id">@actor.Name (@actor.Role)</option>
                        }
                    </select>
                    <small class="text-muted">Press the Ctrl key to select multiple actors.</small>
                </div>

                <!-- الوصف -->
                <div class="col-md-12 mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" name="Description" rows="4"></textarea>
                </div>

                <!-- السعر والوقت -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Price</label>
                    <input type="number" step="0.01" class="form-control" name="Price" >
                    <span asp-validation-for="Movies.Price"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Show Time</label>
                    <input type="datetime-local" class="form-control" name="ShowTime" >
                    <span asp-validation-for="Movies.ShowTime"></span>
                </div>

                <!-- التصنيف والسينما -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Category</label>
                    <select name="CategoryId" class="form-select" required>
                        <option value="">-- Select Category --</option>
                        @foreach (var item in Model.Categories)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Cinema</label>
                    <select name="CinemaId" class="form-select" required>
                        <option value="">-- Select Cinema --</option>
                        @foreach (var item in Model.Cinemas)
                        {
                            <option value="@item.Id">@item.Name</option>
                        }
                    </select>
                </div>

                <!-- الصورة الأساسية -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Main Image</label>
                    <input type="file" class="form-control" name="Img" id="MainImgInput">
                    <img id="MainPreviewImg" src="#" style="display:none; max-width: 150px; margin-top:10px;" class="img-thumbnail" />
                    <span asp-validation-for="Movies.MainImg"></span>
                </div>

                <!-- الصور الفرعية -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Sub Images (Gallery)</label>
                    <input type="file" class="form-control" name="SubImgs" id="SubImgsInput" multiple>
                    <div id="SubImgsPreview" class="d-flex flex-wrap mt-2"></div>
               
                </div>

                <div class="col-12 mt-4">
                    <button type="submit" class="btn btn-primary w-100">Create Movie</button>
                </div>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotifictionPartial">
}

    <script>
        // معاينة الصورة الأساسية
        document.getElementById('MainImgInput').onchange = evt => {
            const [file] = evt.target.files;
            if (file) {
                const preview = document.getElementById('MainPreviewImg');
                preview.src = URL.createObjectURL(file);
                preview.style.display = 'block';
            }
        };

        // معاينة الصور الفرعية
        document.getElementById('SubImgsInput').onchange = function() {
            const container = document.getElementById('SubImgsPreview');
            container.innerHTML = '';
            [...this.files].forEach(file => {
                const img = document.createElement('img');
                img.src = URL.createObjectURL(file);
                img.className = 'img-thumbnail';
                img.style.width = '80px';
                img.style.margin = '5px';
                container.appendChild(img);
            });
        };
    </script>

