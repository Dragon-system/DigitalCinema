@model MoviesVM

<div class="container my-4">
    <!-- Header -->
    <div class="row mb-4 align-items-center bg-white p-3 rounded shadow-sm border-start border-primary border-5">
        <div class="col-md-6">
            <h2 class="display-6 m-0 fw-bold">Mangmint Movies</h2>
        </div>
        <div class="col-md-6 text-md-end">
            <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i>CERATE MOVIE </a>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card border-0 shadow-sm bg-light p-3 mb-4">
        <form method="get" asp-action="Index">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <input type="text" class="form-control" name="Name" value="@Model.FilterName" placeholder="Movie Name">
                </div>
                <div class="col-md-2">
                    <input type="number" class="form-control" name="MainPrice" value="@Model.FilterMinPrice" placeholder="Main Price">
                </div>
                <div class="col-md-2">
                    <input type="number" class="form-control" name="MaxPrice" value="@Model.FilterMaxPrice" placeholder="Max Price">
                </div>
                <div class="col-md-2">
                    <select name="CategoryId" class="form-select">
                        <option value="0">All Categories</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id" selected="@(cat.Id == Model.FilterCategoryId)">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="CinemaId" class="form-select">
                        <option value="0">All Cinemas</option>
                        @foreach (var cin in Model.Cinemas)
                        {
                            <option value="@cin.Id" selected="@(cin.Id == Model.FilterCinemaId)">@cin.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-dark w-100"><i class="bi bi-zoom-in"></i>OK</button>
                </div>
            </div>
        </form>
    </div>

    <!-- Movies Grid -->
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @if (Model.Movies.Any())
        {
            var actorsDict = ViewBag.MovieActors as Dictionary<int, List<ActorMovie>>;

            @foreach (var item in Model.Movies)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 movie-card">
                        <div class="position-relative">
                            <img src="~/images/Movie/@item.MainImg" class="card-img-top" style="height: 300px; object-fit: cover;" alt="@item.Name">
                            <span class="badge bg-primary position-absolute top-0 end-0 m-2 fs-6">@item.Price.ToString("C")</span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@item.Name</h5>
                            <p class="text-muted small mb-2">@item.Category?.Name | @item.Cinema?.Name</p>

                            <!-- عرض الممثلين من الـ Dictionary -->
                            <div class="mb-3">
                                <h6 class="small fw-bold text-secondary border-bottom pb-1">طاقم العمل:</h6>
                                <div class="d-flex flex-wrap gap-1 mt-2">
                                    @if (actorsDict != null && actorsDict.ContainsKey(item.Id))
                                    {
                                        foreach (var am in actorsDict[item.Id].Take(3))
                                        {
                                            <span class="badge bg-white text-dark border shadow-sm">@am.Actor?.Name</span>
                                        }
                                        if (actorsDict[item.Id].Count > 3)
                                        {
                                            <span class="badge bg-light text-muted border">+@(actorsDict[item.Id].Count - 3)</span>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 d-flex justify-content-between pb-3 px-3">
                            <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm px-3 rounded-pill">Edite</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm px-3 rounded-pill"> <i class="bi bi-trash"></i>Delete</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <!-- Pagination Section -->
@if (Model.TotalPages > 1)
{
        <nav class="mt-5 border-top pt-4">
            <ul class="pagination justify-content-center">

                <!-- زر السابق (Previous) -->
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "") shadow-sm">
                    <a class="page-link px-3 py-2 fw-bold"
                       href="@(Model.CurrentPage > 1 ? Url.Action("Index", new { page = Model.CurrentPage - 1, Name = Model.FilterName, MainPrice = Model.FilterMinPrice, MaxPrice = Model.FilterMaxPrice, CategoryId = Model.FilterCategoryId, CinemaId = Model.FilterCinemaId }) : "#")">
                        <i class="bi bi-chevron-double-left"></i> Bak
                    </a>
                </li>

                <!-- أرقام الصفحات -->
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "") shadow-sm">
                        <a class="page-link px-3 py-2 fw-bold"
                           href="@Url.Action("Index", new { page = i, Name = Model.FilterName, MainPrice = Model.FilterMinPrice, MaxPrice = Model.FilterMaxPrice, CategoryId = Model.FilterCategoryId, CinemaId = Model.FilterCinemaId })">
                            @i
                        </a>
                    </li>
                }

                <!-- زر التالي (Next) -->
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "") shadow-sm">
                    <a class="page-link px-3 py-2 fw-bold"
                       href="@(Model.CurrentPage<Model.TotalPages? Url.Action("Index", new { page = Model.CurrentPage + 1, Name = Model.FilterName, MainPrice = Model.FilterMinPrice, MaxPrice = Model.FilterMaxPrice, CategoryId = Model.FilterCategoryId, CinemaId = Model.FilterCinemaId }) : "#")">
                        Next <i class="bi bi-chevron-double-right"></i>
                    </a>
                </li>

            </ul>
        </nav>
}


<style>
    .movie-card:hover {
        transform: translateY(-5px);
        transition: 0.3s;
    }

    .page-item.active .page-link {
        background-color: #333;
        border-color: #333;
    }
</style>

    <script>
        // السكريبت هيفضل زي ما هو عشان الـ SweetAlert
        document.addEventListener("DOMContentLoaded", function() {
            const swalWithBootstrapButtons = Swal.mixin({
                customClass: {
                    confirmButton: "btn btn-success btn-sm mx-2",
                    cancelButton: "btn btn-danger btn-sm mx-2"
                },
                buttonsStyling: false
            });

            const deleteButtons = document.querySelectorAll(".btn-delete");

            deleteButtons.forEach(button => {
                button.addEventListener("click", function(e) {
                    e.preventDefault();
                    const url = this.getAttribute("href");

                    swalWithBootstrapButtons.fire({
                        title: "Sure?",
                        text: "Delete this cinema?",
                        icon: "warning",
                        showCancelButton: true,
                        confirmButtonText: "Yes",
                        cancelButtonText: "No"
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = url;
                        }
                    });
                });
            });
        });
    </script>
