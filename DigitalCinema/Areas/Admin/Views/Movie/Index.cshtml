@model MoviesVM
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">All Movies</h2>
        </div>
        <div class="col-md-6 text-md-end text-start mt-2 mt-md-0">
            <a href="/Admin/Movie/Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Create</a>
        </div>
    </div>

    <!-- Filter Section -->
    <section class="py-3 filter-bar">
        <div class="container">
            <div class="row bg-light p-3 rounded">
                <div class="col-12">
                    <form>
                        <div class="row g-2 align-items-center">

                            <!-- Movie Name -->
                            <div class="col-12 col-md">
                                <input type="text" class="form-control" placeholder="Name" name="Name" value="@ViewBag.Name">
                            </div>

                            <!-- Main Price -->
                            <div class="col-6 col-md">
                                <input type="text" class="form-control" placeholder="Main Price" name="MainPrice" value="@ViewBag.MainPrice">
                            </div>

                            <!-- Max Price -->
                            <div class="col-6 col-md">
                                <input type="text" class="form-control" placeholder="Max Price" name="MaxPrice" value="@ViewBag.MaxPrice">
                            </div>

                            <!-- Category -->
                            <div class="col-6 col-md">
                                @* <input type="text" class="form-control" placeholder="Category Name" name="CategoryName" value="@ViewBag.CategoryName"> *@
                                <select name="CategoryId" class="form-select">
                                    <option class="disabled">All</option>
                                    @foreach (var item in Model.Categories)
                                    {
                                        if (item.Id == ViewBag.CategoryId)
                                        {
                                            <option value="@item.Id" selected>@item.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@item.Id">@item.Name</option>
                                        }
                                    }
                                </select>
                            </div>

                            <!-- Cinema -->
                            <div class="col-6 col-md">
                                @* <input type="text" class="form-control" placeholder="Cinema Name" name="CinemaName" value="@ViewBag.CinemaName"> *@
                                <select name="CinemaId" class="form-select">
                                    <option class="disabled">All</option>
                                    @foreach (var item in Model.Cinemas)
                                    {
                                        if (item.Id == ViewBag.CinemaId)
                                        {
                                            <option value="@item.Id" selected>@item.Name</option>
                                        }
                                        else
                                        {
                                            <option value="@item.Id">@item.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <!-- Button -->
                            <div class="col-12 col-md-auto">
                                <button type="submit" class="btn btn-dark w-100">Filter</button>
                            </div>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </section>
    <div class="container mt-4">

        <!-- الجدول 1: المعلومات الأساسية -->
        <div class="row mb-4">
            <div class="col-12">
                <h5 class="text-white mb-2">Basic Movie Info</h5>
                <div class="table-responsive">
                    <table class="table table-hover custom-table text-center align-middle">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Price</th>
                                <th>Actors</th>
                                <th>Description</th>
                                <th>Category</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Movies)
                            {
                                <tr>
                                    <th>@item.Id</th>
                                    <td>@item.Name</td>
                                    <td>@item.Price.ToString("C")</td>
                                    <td>@item.Actors</td>
                                    <td>@item.Description</td>
                                    <td>@item.Category</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- الجدول 2: التفاصيل والصور + Actions -->
        <div class="row">
            <div class="col-12">
                <h5 class="text-white mb-2">Movie Details & Actions</h5>
                <div class="table-responsive">
                    <table class="table table-hover custom-table text-center align-middle">
                        <thead>
                            <tr>
                                <th>Cinema</th>
                                <th>ShowTime</th>
                                <th>MainImg</th>
                                <th>SupImg</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Movies)
                            {
                                <tr>
                                    <td>@item.Cinema</td>
                                    <td>@item.ShowTime</td>
                                    <td>
                                        <img src="~/images/Cinema/@item.MainImg" alt="@item.Name" style="max-width: 100px; border: 1px solid #ccc; padding:5px; border-radius:10px">
                                    </td>
                                    <td>
                                        <img src="~/images/Cinema/@item.SaubImg" alt="@item.Name" style="max-width: 100px; border: 1px solid #ccc; padding:5px; border-radius:10px">
                                    </td>
                                    <td>
                                        <a href="/Admin/Movie/Update/@item.Id" class="btn btn-warning">
                                            <i class="bi bi-pencil-square"></i> Edit
                                        </a>
                                        <a href="/Admin/Movie/Delete/@item.Id" class="btn btn-danger btn-delete">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    <div class="row">
        <div class="col-12 d-flex justify-content-center">
            <nav aria-label="Page navigation example">
                <ul class="pagination justify-content-center">
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item"><a class="page-link" href="/Admin/Movie/Index?page=@(Model.CurrentPage - 1)">Previous</a></li>
                    }
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        @if (i == Model.CurrentPage)
                        {
                            <li class="page-item active"><a class="page-link" href="/Admin/Movie/Index?page=@i">@i</a></li>
                        }
                        else
                        {
                            <li class="page-item"><a class="page-link" href="/Admin/Movie/Index?page=@i">@i</a></li>
                        }
                    }
                    @if (Model.CurrentPage != Model.TotalPages)
                    {
                        <li class="page-item"><a class="page-link" href="/Admin/Movie/Index?page=@(Model.CurrentPage + 1)">Next</a></li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const deleteButtons = document.querySelectorAll(".btn-delete");

        deleteButtons.forEach(button => {
            button.addEventListener("click", function (e) {
                e.preventDefault(); // stop normal navigation

                const url = this.getAttribute("href");

                Swal.fire({
                    title: "Are you sure?",
                    text: "This action cannot be undone!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#d33",
                    cancelButtonColor: "#3085d6",
                    confirmButtonText: "Yes, delete it!"
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                          title: "Deleted!",
                          text: "Your file has been deleted.",
                          icon: "success"
                        });

                        // Redirect to delete URL
                        window.location.href = url;
                    }
                });
            });
        });
    });
</script>