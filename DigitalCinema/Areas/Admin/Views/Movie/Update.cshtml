@model MovieWebSubImgVM

<div class="container my-5">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-dark text-white p-3">
            <h2 class="h4 mb-0"><i class="fas fa-edit me-2"></i>Edit Movie: @Model.Movie.Name</h2>
        </div>
        <div class="card-body p-4">
            <form asp-action="Update" method="post" enctype="multipart/form-data">
                <!-- المعرف الخفي للفيلم -->
                <input type="hidden" name="Id" value="@Model.Movie.Id" />

                <div class="row">
                    <!-- معلومات الفيلم الأساسية -->
                    <div class="col-md-8 mb-4">
                        <label class="form-label fw-bold">Move Name</label>
                        <input class="form-control form-control-lg" name="Name" value="@Model.Movie.Name" required>
                    </div>

                    <div class="col-md-4 mb-4">
                        <label class="form-label fw-bold">Price</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" step="0.01" class="form-control form-control-lg" name="Price" value="@Model.Movie.Price">
                        </div>
                    </div>

                    <!-- شريط صور الممثلين الحاليين (Scroll Bar) -->
                    <div class="col-md-12 mb-4">
                        <label class="form-label fw-bold text-primary"><i class="fas fa-users me-1"></i> Current Cast (Scroll Right/Left):</label>

                        <div class="actor-scroll-wrapper border rounded-3 bg-light p-3">
                            <div class="d-flex overflow-auto pb-2 actor-list" style="gap: 25px; scrollbar-width: thin;">
                                @if (Model.ActorMovie != null && Model.ActorMovie.Any())
                                {
                                    @foreach (var am in Model.ActorMovie)
                                    {
                                        <div class="text-center flex-shrink-0" style="width: 100px;">
                                            <div class="actor-img-container mb-2 shadow-sm">
                                                <img src="~/images/Actor/@am.Actor.Img"
                                                     alt="@am.Actor.Name"
                                                     class="rounded-circle border border-3 border-white"
                                                     style="width: 80px; height: 80px; object-fit: cover;">
                                            </div>
                                            <div class="small fw-bold text-truncate px-1">@am.Actor.Name</div>
                                            <span class="badge bg-secondary rounded-pill" style="font-size: 10px;">@am.Actor.Role</span>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="text-muted p-3"><i class="fas fa-info-circle me-1"></i> No actors are currently associated with this movie.</div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- اختيار/تغيير الممثلين -->
                    <div class="col-md-12 mb-4">
                        <label class="form-label fw-bold">Edite(Add New Actor):</label>
                        <select name="selectedActorIds" class="form-select" multiple style="height: 150px;">
                            @foreach (var actor in Model.AllActors)
                            {
                                bool isSelected = Model.ActorMovie.Any(am => am.ActorId == actor.Id);
                                <option value="@actor.Id" selected="@isSelected">@actor.Name (@actor.Role)</option>
                            }
                        </select>
                        <div class="form-text mt-1 text-muted"><i class="fas fa-keyboard me-1"></i> Press the Ctrl key to select multiple actors.</div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">Categories</label>
                        <select name="CategoryId" class="form-select">
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.Id" selected="@(cat.Id == Model.Movie.CategoryId)">@cat.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">Cinemas</label>
                        <select name="CinemaId" class="form-select">
                            @foreach (var cin in Model.Cinemas)
                            {
                                <option value="@cin.Id" selected="@(cin.Id == Model.Movie.CinemaId)">@cin.Name</option>
                            }
                        </select>
                    </div>

                    <!-- الصور -->
                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">Main Img</label>
                        <input type="file" class="form-control mb-3" name="Img" id="MainImgInput">
                        <div class="p-2 border rounded bg-light text-center">
                            <img id="MainPreviewImg" src="~/images/Movie/@Model.Movie.MainImg"
                                 class="img-fluid rounded shadow-sm" style="max-height: 250px;">
                        </div>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label fw-bold">معرض الصور (Sub Images)</label>
                        <input type="file" class="form-control mb-3" name="SubImgs" id="SubImgsInput" multiple>
                        <div id="SubImgsPreview" class="d-flex flex-wrap gap-2 border rounded bg-light p-3" style="min-height: 100px;">
                            @foreach (var sub in Model.SubImgs)
                            {
                                <img src="~/images/Movie/SubImgs/@sub.SubImg" class="img-thumbnail" style="width: 85px; height: 85px; object-fit: cover;">
                            }
                        </div>
                    </div>

                    <div class="col-md-12 mb-4">
                        <label class="form-label fw-bold">Description</label>
                        <textarea class="form-control" name="Description" rows="4">@Model.Movie.Description</textarea>
                    </div>

                    <div class="col-12 mt-3 text-end border-top pt-4">
                        <a asp-action="Index" class="btn btn-light btn-lg px-4 me-2">Ext</a>
                        <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">Update</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotifictionPartial">
}
<style>
    /* تنسيق شريط التمرير الأفقي للممثلين */
    .actor-scroll-wrapper {
        position: relative;
    }

    .actor-list::-webkit-scrollbar {
        height: 8px;
    }

    .actor-list::-webkit-scrollbar-track {
        background: #e9ecef;
        border-radius: 10px;
    }

    .actor-list::-webkit-scrollbar-thumb {
        background: #adb5bd;
        border-radius: 10px;
    }

        .actor-list::-webkit-scrollbar-thumb:hover {
            background: #6c757d;
        }

    .actor-img-container {
        display: inline-block;
        transition: transform 0.2s ease-in-out;
    }

        .actor-img-container:hover {
            transform: scale(1.1);
        }
</style>


    <script>
        // معاينة الصورة الأساسية
        document.getElementById('MainImgInput').onchange = e => {
            const [file] = e.target.files;
            if (file) {
                const preview = document.getElementById('MainPreviewImg');
                preview.src = URL.createObjectURL(file);
            }
        };

        // معاينة الصور الفرعية
        document.getElementById('SubImgsInput').onchange = function() {
            const container = document.getElementById('SubImgsPreview');
            container.innerHTML = '';
            [...this.files].forEach(file => {
                const img = document.createElement('img');
                img.src = URL.createObjectURL(file);
                img.className = 'img-thumbnail';
                img.style.width = '85px';
                img.style.height = '85px';
                img.style.objectFit = 'cover';
                container.appendChild(img);
            });
        };
    </script>
}
