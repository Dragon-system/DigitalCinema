@model CinemasVM

<div class="container my-4">
    <div class="row mb-4 align-items-center bg-white p-2 rounded shadow-sm border-start border-success border-5">
        <div class="col-md-6">
            <h4 class="m-0 fw-bold text-dark">Cinema Management</h4>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="/Admin/Cinema/Create" class="btn btn-success btn-sm px-3 rounded-pill">
                <i class="bi bi-plus-circle"></i> Add New Cinema
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm bg-light p-3 mb-3">
        <form method="get" asp-action="Index">
            <div class="row g-2 align-items-end">
                <div class="col-md-10">
                    <label class="small fw-bold text-muted mb-1">Search Cinema</label>
                    <input type="text" class="form-control form-control-sm" placeholder="Search..." name="query" value="@Model.Query">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark btn-sm w-100"><i class="bi bi-funnel"></i> Filter</button>
                </div>
            </div>
        </form>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover text-center align-middle mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th scope="col" class="py-2 small">#ID</th>
                        <th scope="col" class="py-2 small">Logo</th>
                        <th scope="col" class="py-2 small">Name</th>
                        <th scope="col" class="py-2 small">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Cinemas)
                    {
                        <tr>
                            <td class="text-muted small">@item.Id</td>
                            <td>
                                <div class="d-inline-block p-1 border rounded bg-white shadow-sm">
                                    <img src="~/images/Cinema/@item.Img"
                                         alt="@item.Name"
                                         style="width: 60px; height: 35px; object-fit: contain;">
                                </div>
                            </td>
                            <td class="fw-bold text-secondary">@item.Name</td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a href="/Admin/Cinema/Update/@item.Id" class="btn btn-outline-warning btn-sm px-2 rounded-pill" style="font-size: 0.8rem;">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <button href="/Admin/Cinema/Delete/@item.Id" class="btn btn-outline-danger btn-sm px-2 rounded-pill btn-delete" style="font-size: 0.8rem;">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4 border-top pt-3">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link shadow-sm" href="/Admin/Cinema/Index?page=@(Model.CurrentPage - 1)&query=@Model.Query">Previous</a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link shadow-sm" href="/Admin/Cinema/Index?page=@i&query=@Model.Query">@i</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link shadow-sm" href="/Admin/Cinema/Index?page=@(Model.CurrentPage + 1)&query=@Model.Query">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

<style>
    /* تصغير حجم الخط العام للجدول */
    .table {
        font-size: 0.9rem;
    }

        .table thead th {
            font-weight: 500;
            text-transform: capitalize;
            font-size: 0.8rem;
        }

    .page-item.active .page-link {
        background-color: #198754;
        border-color: #198754;
    }

    /* تخفيف حدة الـ hover */
    .table tbody tr:hover {
        background-color: #f8f9fa;
    }
</style>

<script>
    // السكريبت هيفضل زي ما هو عشان الـ SweetAlert
    document.addEventListener("DOMContentLoaded", function() {
        const swalWithBootstrapButtons = Swal.mixin({
            customClass: {
                confirmButton: "btn btn-success btn-sm mx-2",
                cancelButton: "btn btn-danger btn-sm mx-2"
            },
            buttonsStyling: false
        });

        const deleteButtons = document.querySelectorAll(".btn-delete");

        deleteButtons.forEach(button => {
            button.addEventListener("click", function(e) {
                e.preventDefault();
                const url = this.getAttribute("href");

                swalWithBootstrapButtons.fire({
                    title: "Sure?",
                    text: "Delete this cinema?",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Yes",
                    cancelButtonText: "No"
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = url;
                    }
                });
            });
        });
    });
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotifictionPartial">
}
