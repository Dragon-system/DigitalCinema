@model ActorsVM

<div class="container my-4">
    <div class="row mb-4 align-items-center bg-white p-3 rounded shadow-sm border-start border-success border-5">
        <div class="col-md-6">
            <h2 class="display-6 m-0 fw-bold">All Actors</h2>
        </div>
        <div class="col-md-6 text-md-end">
            <a href="/Admin/Actor/Create" class="btn btn-success px-4 rounded-pill">
                <i class="bi bi-plus-circle"></i> Create New Actor
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm bg-light p-3 mb-4">
        <form method="get" asp-action="Index">
            <div class="row g-2 align-items-end">
                <div class="col-md-10">
                    <label class="small fw-bold text-secondary">Search Actor</label>
                    <input type="text" class="form-control" placeholder="Search by name or role..." name="query" value="@Model.Query">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark w-100"><i class="bi bi-funnel"></i> Filter</button>
                </div>
            </div>
        </form>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover text-center align-middle mb-0">
                <thead class="bg-dark text-white">
                    <tr>
                        <th scope="col" class="py-3">#ID</th>
                        <th scope="col" class="py-3">Photo</th>
                        <th scope="col" class="py-3">Actor Name</th>
                        <th scope="col" class="py-3">Role</th>
                        <th scope="col" class="py-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Actors)
                    {
                        <tr>
                            <td class="fw-bold">@item.Id</td>
                            <td>
                                <img src="~/images/Actor/@item.Img"
                                     alt="@item.Name"
                                     class="rounded-circle shadow-sm border"
                                     style="width: 60px; height: 60px; object-fit: cover;">
                            </td>
                            <td class="fw-semibold">@item.Name</td>
                            <td><span class="badge bg-light text-dark border">@item.Role</span></td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a href="/Admin/Actor/Update/@item.Id" class="btn btn-outline-warning btn-sm px-3 rounded-pill">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <a href="/Admin/Actor/Delete/@item.Id" class="btn btn-outline-danger btn-sm px-3 rounded-pill btn-delete">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-5 border-top pt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link shadow-sm" href="/Admin/Actor/Index?page=@(Model.CurrentPage - 1)&query=@Model.Query">
                        <i class="bi bi-chevron-left"></i> Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link shadow-sm" href="/Admin/Actor/Index?page=@i&query=@Model.Query">@i</a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link shadow-sm" href="/Admin/Actor/Index?page=@(Model.CurrentPage + 1)&query=@Model.Query">
                        Next <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<style>
    /* تحسين شكل الجدول والخطوط */
    .table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .table tbody tr {
        transition: all 0.2s;
    }

        .table tbody tr:hover {
            background-color: rgba(0,0,0,0.02);
        }

    .page-item.active .page-link {
        background-color: #198754; /* Green matching the Create button */
        border-color: #198754;
    }

    .page-link {
        color: #333;
        border-radius: 5px;
        margin: 0 3px;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const swalWithBootstrapButtons = Swal.mixin({
            customClass: {
                confirmButton: "btn btn-success mx-2",
                cancelButton: "btn btn-danger mx-2"
            },
            buttonsStyling: false
        });

        const deleteButtons = document.querySelectorAll(".btn-delete");

        deleteButtons.forEach(button => {
            button.addEventListener("click", function(e) {
                e.preventDefault();
                const url = this.getAttribute("href");

                swalWithBootstrapButtons.fire({
                    title: "Are you sure?",
                    text: "This actor profile will be removed!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonText: "Yes, delete it!",
                    cancelButtonText: "No, cancel!",
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = url;
                    }
                });
            });
        });
    });
</script>
@section Scripts {
    <partial name="_NotifictionPartial">
}
