@model DigitalCinema.Models.Hall

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="card-title mb-0">إنشاء قاعة جديدة</h3>
        </div>
        <div class="card-body">
            <form asp-action="CreateHall" method="post">
                <div class="mb-3">
                    <label class="form-label">اسم القاعة</label>
                    <input name="hallName" class="form-control" placeholder="مثلاً: القاعة الكبرى" required />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">عدد الصفوف</label>
                        <input type="number" name="rows" class="form-control" min="1" max="26" value="5" required />
                        <small class="text-muted">الصفوف ترمز لها بالحروف (A, B, C...)</small>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">عدد الكراسي في كل صف</label>
                        <input type="number" name="cols" class="form-control" min="1" value="10" required />
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success px-5">حفظ وإنشاء الكراسي</button>
                    <a asp-action="Index" class="btn btn-secondary px-5">إلغاء</a>
                </div>
            </form>
        </div>
    </div>
</div>
