<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DE Cinema</title>

    <!-- Bootstrap 5 RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Bebas+Neue&display=swap" rel="stylesheet" />
    <!-- Layout CSS -->
    <link rel="stylesheet" href="~/css/layoutLogin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css">
    @* Page-specific styles *@

  
</head>
<body>

    <!-- ═══════════════════ NAVBAR ═══════════════════ -->
    <nav class="c-navbar">
        <!-- Hamburger -->
        

        <!-- Brand -->
        <a class="c-brand" asp-controller="Home" asp-action="Index">
            <div class="c-brand-icon"><i class="bi bi-film"></i></div>
            <span class="c-brand-name">DE Cinema</span>
        </a>
        <!-- Actions -->
       
    </nav>

   
    <!-- Tooltip -->
    <div class="sidebar-tooltip" id="sidebarTip"></div>

    <!-- ═══════════════════ MAIN ═══════════════════ -->
    <main class="c-main" id="mainArea">

        <!-- Breadcrumb -->
        

        <!-- Page Content -->
        <div class="c-scroll">

            @RenderBody()
      
        </div>

        <!-- ═══════════════════ FOOTER ═══════════════════ -->

    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Layout JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/layoutLogin.js" asp-append-version="true"></script>
    <script src="~/js/login.js" asp-append-version="true"></script>
   
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    @RenderSection("Scripts", false)

</body>
</html>
